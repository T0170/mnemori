{
  "name": "mnemori",
  "version": "0.3.0",
  "description": "Spoken memory — narrate your screen, capture your reasoning, refine it into documentation and coaching",
  "author": "Third Feather Capital Inc",
  "license": "UNLICENSED",
  "homepage": "https://mnemori.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemori/mnemori-app"
  },
  "private": true,
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "rebuild": "electron-rebuild",
    "postinstall": "node scripts/patch-builder.js",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mnemori.app",
    "productName": "Mnemori",
    "files": [
      "src/main/**/*",
      "dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico",
      "publisherName": "Third Feather Capital Inc"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "better-sqlite3": "^11.5.0",
    "ffmpeg-static": "^5.3.0",
    "openai": "^6.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
