{
  "name": "mnemori",
  "version": "0.6.2",
  "description": "Spoken memory — narrate your screen, capture your reasoning, refine it into documentation and coaching",
  "author": "Third Feather Capital Inc",
  "license": "UNLICENSED",
  "homepage": "https://mnemori.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/T0170/mnemori"
  },
  "private": true,
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "rebuild": "node -e \"const v=require('electron/package.json').version;const{execSync}=require('child_process');execSync(`cd node_modules/better-sqlite3 && node-gyp rebuild --target=${v} --arch=x64 --dist-url=https://electronjs.org/headers --runtime=electron --build-from-source`,{stdio:'inherit'})\"",
    "postinstall": "node scripts/patch-builder.js",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mnemori.app",
    "productName": "Mnemori",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "T0170",
      "repo": "mnemori"
    },
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "!dist/mac/**",
      "!dist/mac-*/**",
      "!dist/win-unpacked/**",
      "!dist/*.dmg",
      "!dist/*.zip",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "!dist/*.yml"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico",
      "publisherName": "Third Feather Capital Inc",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "openai": "^6.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^25.1.8",
    "node-gyp": "^12.3.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
